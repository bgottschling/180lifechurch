# Password protection for preview deployment
# Generate with: node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');const h=c.scryptSync('YOUR_PASSWORD',s,64).toString('hex');console.log(s+':'+h)"
PREVIEW_PASSWORD_HASH=

# Set to "true" to enable password protection
PREVIEW_PASSWORD_ENABLED=false

# WordPress headless CMS (optional — site falls back to hardcoded defaults if not set)
# WORDPRESS_URL=https://cms.180lifechurch.org

# Shared secret for on-demand revalidation webhook from WordPress
# WORDPRESS_REVALIDATION_SECRET=
